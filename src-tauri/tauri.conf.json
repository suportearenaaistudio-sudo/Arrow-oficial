{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Arrow",
  "version": "0.5.1",
  "identifier": "com.arrow.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5555",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "macOSPrivateApi": false,
    "windows": [
      {
        "label": "main",
        "title": "Arrow",
        "width": 1280,
        "height": 860,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "decorations": false,
        "transparent": true,
        "shadow": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Productivity",
    "shortDescription": "Produtividade pessoal — método 12 Semanas",
    "longDescription": "Arrow — gestão de ciclos, metas, tarefas, hábitos e finanças com vault local portável.",
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IERDMjcxM0QwNjhFQTA2NkMKUldSc0J1cG8wQk1uM0lGVWZxbVNhT1BsSUc2Ni9FaFU5anhoWWJFL2NIRmtxa0piUnB4Mnluc3AK",
      "endpoints": [
        "https://github.com/suportearenaaistudio-sudo/Arrow-oficial/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
